<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Blogify - Discover Amazing Stories</title>
    <style>
        /* ===== HERO SECTION ===== */
        .hero-landing {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a855f7 100%);
            color: white;
            padding: 80px 0 100px;
            position: relative;
            overflow: hidden;
        }

        .hero-landing::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 600px;
            height: 600px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }

        .hero-landing::after {
            content: '';
            position: absolute;
            bottom: -40%;
            left: -5%;
            width: 400px;
            height: 400px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

        .hero-landing h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1rem;
            position: relative;
            z-index: 1;
        }

        .hero-landing p {
            font-size: 1.25rem;
            opacity: 0.9;
            margin-bottom: 2rem;
            position: relative;
            z-index: 1;
        }

        .hero-landing .btn-light {
            background: white;
            color: #6366f1;
            border: none;
            font-weight: 600;
            padding: 0.875rem 2rem;
            border-radius: 50rem;
            transition: all 0.3s ease;
        }

        .hero-landing .btn-light:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .hero-landing .btn-outline-light {
            border: 2px solid rgba(255,255,255,0.5);
            color: white;
            font-weight: 600;
            padding: 0.875rem 2rem;
            border-radius: 50rem;
            transition: all 0.3s ease;
        }

        .hero-landing .btn-outline-light:hover {
            background: rgba(255,255,255,0.15);
            border-color: white;
        }

        /* ===== SECTION HEADERS ===== */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .section-title {
            font-weight: 800;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .view-all-link {
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            color: var(--primary);
            transition: all 0.2s;
        }

        .view-all-link:hover {
            opacity: 0.8;
            transform: translateX(4px);
        }

        /* ===== FULL-WIDTH HORIZONTAL BLOG CARD ===== */
        .blog-card-fw {
            display: flex;
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: all 0.3s ease;
            margin-bottom: 1.5rem;
            width: 100%;
        }

        body.dark-mode .blog-card-fw {
            background: #1a1a2e;
            border-color: #2d2d44;
        }

        .blog-card-fw:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .blog-card-fw-img {
            position: relative;
            width: 320px;
            min-width: 320px;
            overflow: hidden;
        }

        .blog-card-fw-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .blog-card-fw:hover .blog-card-fw-img img {
            transform: scale(1.08);
        }

        .blog-card-fw-body {
            flex: 1;
            padding: 1.75rem 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-width: 0;
        }

        .blog-card-fw-tags {
            margin-bottom: 0.75rem;
        }

        .tag-pill {
            display: inline-block;
            padding: 0.3rem 0.85rem;
            border-radius: 50rem;
            font-size: 0.75rem;
            font-weight: 600;
            background: rgba(99, 102, 241, 0.1);
            color: var(--primary);
            text-decoration: none;
            margin-right: 0.5rem;
            transition: all 0.2s;
        }

        .tag-pill:hover {
            background: var(--primary);
            color: #fff;
        }

        .blog-card-fw-title {
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
            color: inherit;
            text-decoration: none;
            display: block;
            line-height: 1.4;
        }

        .blog-card-fw-title:hover {
            color: var(--primary);
        }

        .blog-card-fw-excerpt {
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 1.25rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .blog-card-fw-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        body.dark-mode .blog-card-fw-footer {
            border-color: #2d2d44;
        }

        .author-chip {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: inherit;
            transition: opacity 0.2s;
        }

        .author-chip:hover {
            opacity: 0.8;
        }

        .author-chip img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--border);
        }

        body.dark-mode .author-chip img {
            border-color: #2d2d44;
        }

        .author-chip-name {
            font-weight: 600;
            font-size: 0.9rem;
        }

        .author-chip-meta {
            font-size: 0.8rem;
            color: var(--muted);
        }

        .blog-stats-row {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.85rem;
            color: var(--muted);
        }

        .read-btn-sm {
            padding: 0.5rem 1.25rem;
            border-radius: 50rem;
            font-weight: 600;
            font-size: 0.85rem;
        }

        /* Featured badge */
        .featured-ribbon {
            position: absolute;
            top: 16px;
            left: 16px;
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
            padding: 0.4rem 1rem;
            border-radius: 50rem;
            font-size: 0.75rem;
            font-weight: 700;
            z-index: 2;
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        }

        /* ===== EMPTY STATE ===== */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
        }

        .empty-state i {
            font-size: 4rem;
            color: var(--muted);
            opacity: 0.4;
            margin-bottom: 1.5rem;
        }

        .empty-state h4 {
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: var(--muted);
            margin-bottom: 1.5rem;
        }

        /* ===== PAGINATION ===== */
        .pagination .page-link {
            border-radius: 10px;
            margin: 0 4px;
            border: 1px solid var(--border);
            color: var(--muted);
            font-weight: 600;
            padding: 0.6rem 1rem;
        }

        .pagination .page-item.active .page-link {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .pagination .page-link:hover {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .hero-landing h1 {
                font-size: 2rem;
            }

            .blog-card-fw {
                flex-direction: column;
            }

            .blog-card-fw-img {
                width: 100%;
                min-width: auto;
                height: 200px;
            }

            .blog-card-fw-body {
                padding: 1.25rem;
            }

            .blog-card-fw-title {
                font-size: 1.1rem;
            }

            .blog-card-fw-footer {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
<base target="_blank">
</head>
<body>
    <%- include("./partials/nave") %>

    <!-- Hero (shown to everyone, but CTA only for guests) -->
    <header class="hero-landing text-center">
        <div class="container position-relative" style="z-index: 1;">
            <h1>Welcome to Blogify</h1>
            <p>Discover stories, insights, and ideas from amazing writers around the world.</p>
            <% if (!locals.user) { %>
                <a href="/user/signup" class="btn btn-light btn-lg rounded-pill me-3 mb-2">
                    <i class="fas fa-pen-fancy"></i> Start Writing
                </a>
                <a href="/user/signin" class="btn btn-outline-light btn-lg rounded-pill mb-2">
                    <i class="fas fa-book-reader"></i> Explore Blogs
                </a>
            <% } else { %>
                <a href="/blogs/add-new" class="btn btn-light btn-lg rounded-pill">
                    <i class="fas fa-pen"></i> Write a New Blog
                </a>
            <% } %>
        </div>
    </header>

    <main class="container my-5">

        <!-- Featured Blogs -->
        <% if (typeof featuredBlogs !== 'undefined' && featuredBlogs.length > 0) { %>
            <section class="mb-5">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-star text-warning"></i> Featured Stories
                    </h2>
                    <a href="/blogs/featured/list" class="view-all-link">
                        View All <i class="fas fa-arrow-right"></i>
                    </a>
                </div>

                <% featuredBlogs.forEach(blog => { %>
                    <div class="blog-card-fw">
                        <div class="blog-card-fw-img">
                            <% if (blog.coverImageURL) { %>
                                <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" loading="lazy">
                            <% } else { %>
                                <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                    <i class="fas fa-image fa-3x text-muted"></i>
                                </div>
                            <% } %>
                            <span class="featured-ribbon">
                                <i class="fas fa-star"></i> Featured
                            </span>
                        </div>

                        <div class="blog-card-fw-body">
                            <div class="blog-card-fw-tags">
                                <% if (blog.tags && blog.tags.length > 0) { %>
                                    <% blog.tags.slice(0, 3).forEach(tag => { %>
                                        <a href="/blogs/tags/<%= tag %>" class="tag-pill"><%= tag %></a>
                                    <% }) %>
                                <% } %>
                            </div>

                            <a href="/blogs/<%= blog._id %>" class="blog-card-fw-title"><%= blog.title %></a>
                            <p class="blog-card-fw-excerpt"><%= blog.excerpt || (blog.body ? blog.body.substring(0, 180) : '') %>...</p>

                            <div class="blog-card-fw-footer">
                                <% if (blog.createdBy) { %>
                                    <a href="/profile/<%= blog.createdBy._id %>" class="author-chip">
                                        <img src="<%= blog.createdBy.profileImageURL || '/imgs/default.png' %>" 
                                             alt="<%= blog.createdBy.fullName %>"
                                             onerror="this.src='/imgs/default.png';">
                                        <div>
                                            <div class="author-chip-name"><%= blog.createdBy.fullName %></div>
                                            <div class="author-chip-meta"><%= blog.readingTime || 3 %> min read</div>
                                        </div>
                                    </a>
                                <% } else { %>
                                    <div class="author-chip">
                                        <img src="/imgs/default.png" alt="Unknown">
                                        <div>
                                            <div class="author-chip-name">Unknown Author</div>
                                            <div class="author-chip-meta">3 min read</div>
                                        </div>
                                    </div>
                                <% } %>

                                <div class="d-flex align-items-center gap-3">
                                    <div class="blog-stats-row">
                                        <span class="stat-item"><i class="fas fa-eye"></i> <%= blog.viewCount || 0 %></span>
                                        <span class="stat-item"><i class="fas fa-heart"></i> <%= blog.likes ? blog.likes.length : 0 %></span>
                                    </div>
                                    <a href="/blogs/<%= blog._id %>" class="btn btn-primary read-btn-sm">
                                        Read <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </section>
            <hr class="my-5">
        <% } %>

        <!-- Latest Blogs -->
        <section>
            <div class="section-header">
                <h2 class="section-title">
                    <i class="fas fa-fire text-danger"></i> Latest Stories
                </h2>
            </div>

            <% if (!blogs || blogs.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h4>No blogs found</h4>
                    <p>Be the first to write a blog!</p>
                    <% if (locals.user) { %>
                        <a href="/blogs/add-new" class="btn btn-primary btn-lg rounded-pill">
                            <i class="fas fa-pen"></i> Write First Blog
                        </a>
                    <% } else { %>
                        <a href="/user/signup" class="btn btn-primary btn-lg rounded-pill">
                            <i class="fas fa-user-plus"></i> Sign Up to Write
                        </a>
                    <% } %>
                </div>
            <% } else { %>
                <% blogs.forEach(blog => { %>
                    <div class="blog-card-fw animate-in">
                        <div class="blog-card-fw-img">
                            <% if (blog.coverImageURL) { %>
                                <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" loading="lazy">
                            <% } else { %>
                                <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                    <i class="fas fa-image fa-3x text-muted"></i>
                                </div>
                            <% } %>
                        </div>

                        <div class="blog-card-fw-body">
                            <div class="blog-card-fw-tags">
                                <% if (blog.tags && blog.tags.length > 0) { %>
                                    <% blog.tags.slice(0, 3).forEach(tag => { %>
                                        <a href="/blogs/tags/<%= tag %>" class="tag-pill"><%= tag %></a>
                                    <% }) %>
                                <% } %>
                            </div>

                            <a href="/blogs/<%= blog._id %>" class="blog-card-fw-title"><%= truncate(blog.title, 80) %></a>
                            <p class="blog-card-fw-excerpt"><%= truncate(blog.excerpt || (blog.body ? blog.body.substring(0, 180) : ''), 140) %></p>

                            <div class="blog-card-fw-footer">
                                <% if (blog.createdBy) { %>
                                    <a href="/profile/<%= blog.createdBy._id %>" class="author-chip">
                                        <img src="<%= blog.createdBy.profileImageURL || '/imgs/default.png' %>" 
                                             alt="<%= blog.createdBy.fullName %>"
                                             onerror="this.src='/imgs/default.png';">
                                        <div>
                                            <div class="author-chip-name"><%= blog.createdBy.fullName %></div>
                                            <div class="author-chip-meta">
                                                <% if (blog.readingTime) { %>
                                                    <%= blog.readingTime %> min read
                                                <% } else { %>
                                                    3 min read
                                                <% } %>
                                            </div>
                                        </div>
                                    </a>
                                <% } else { %>
                                    <div class="author-chip">
                                        <img src="/imgs/default.png" alt="Unknown">
                                        <div>
                                            <div class="author-chip-name">Unknown Author</div>
                                            <div class="author-chip-meta">3 min read</div>
                                        </div>
                                    </div>
                                <% } %>

                                <div class="d-flex align-items-center gap-3">
                                    <div class="blog-stats-row">
                                        <span class="stat-item"><i class="fas fa-eye"></i> <%= blog.viewCount || 0 %></span>
                                        <span class="stat-item"><i class="fas fa-heart"></i> <%= blog.likes ? blog.likes.length : 0 %></span>
                                    </div>
                                    <a href="/blogs/<%= blog._id %>" class="btn btn-primary read-btn-sm">
                                        Read <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                    <nav class="mt-5">
                        <ul class="pagination justify-content-center">
                            <% for (let i = 1; i <= totalPages; i++) { %>
                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                    <a class="page-link" href="/?page=<%= i %>"><%= i %></a>
                                </li>
                            <% } %>
                        </ul>
                    </nav>
                <% } %>
            <% } %>
        </section>
    </main>

    <%- include("./partials/scripts") %>
</body>
</html>
