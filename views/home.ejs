<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Blogify - Discover Amazing Stories</title>
</head>
<body>
    <%- include("./partials/nave") %>

    <%# ==================== LOGGED IN: Show Blog Content ==================== %>
    <% if (locals.user) { %>

        <main class="container my-5" style="margin-top: 10px;">


            <%# Featured Blogs Section %>
            <% if (typeof featuredBlogs !== 'undefined' && featuredBlogs.length > 0) { %>
                <section class="mb-5">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h2 class="fw-bold">
                            <i class="fas fa-star text-warning"></i> Featured Stories
                        </h2>
                        <a href="/blogs/featured/list" class="text-primary text-decoration-none small fw-medium">
                            View All <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="row">
                        <% featuredBlogs.forEach(blog => { %>
                            <div class="col-lg-4 col-md-6 mb-4">
                                <div class="card blog-card h-100">
                                    <div class="position-relative">
                                        <% if (blog.coverImageURL) { %>
                                            <img src="<%= blog.coverImageURL %>" 
                                                 class="card-img-top blog-card-image" 
                                                 alt="<%= blog.title %>"
                                                 loading="lazy">
                                        <% } else { %>
                                            <div class="bg-light d-flex align-items-center justify-content-center blog-card-image">
                                                <i class="fas fa-image fa-3x text-muted"></i>
                                            </div>
                                        <% } %>
                                        <div class="blog-card-overlay"></div>
                                        <div class="position-absolute top-0 start-0 m-2">
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-star"></i> Featured
                                            </span>
                                        </div>
                                    </div>

                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title fw-bold mb-2"><%= blog.title %></h5>
                                        <p class="card-text text-muted flex-grow-1">
                                            <%= blog.excerpt || (blog.body ? blog.body.substring(0, 100) : '') %>...
                                        </p>

                                        <div class="d-flex align-items-center justify-content-between mt-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <% if (blog.createdBy) { %>
                                                    <a href="/profile/<%= blog.createdBy._id %>" class="d-flex align-items-center gap-2 text-decoration-none text-dark">
                                                        <img src="<%= blog.createdBy.profileImageURL || '/imgs/default.png' %>" 
                                                             alt="<%= blog.createdBy.fullName %>" 
                                                             width="32" height="32" 
                                                             class="rounded-circle"
                                                             onerror="this.src='/imgs/default.png';">
                                                        <div>
                                                            <small class="fw-bold d-block"><%= blog.createdBy.fullName %></small>
                                                            <small class="text-muted"><%= blog.readingTime %> min read</small>
                                                        </div>
                                                    </a>
                                                <% } else { %>
                                                    <img src="/imgs/default.png" 
                                                         alt="Unknown Author" 
                                                         width="32" height="32" 
                                                         class="rounded-circle">
                                                    <div>
                                                        <small class="fw-bold d-block">Unknown Author</small>
                                                        <small class="text-muted"><%= blog.readingTime %> min read</small>
                                                    </div>
                                                <% } %>
                                            </div>
                                            <a href="/blogs/<%= blog._id %>" class="btn btn-sm btn-primary rounded-pill">
                                                Read
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </section>
                <hr class="my-5">
            <% } %>

            <%# Latest Blogs Section %>
            <section>
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h2 class="fw-bold">
                        <i class="fas fa-fire text-danger"></i> Latest Stories
                    </h2>
                </div>

                <% if (!blogs || blogs.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-inbox fa-5x text-muted mb-3"></i>
                        <h4 class="text-muted">No blogs found</h4>
                        <p class="text-muted mb-4">Be the first to write a blog!</p>
                        <a href="/blogs/add-new" class="btn btn-primary btn-lg rounded-pill">
                            <i class="fas fa-pen"></i> Write First Blog
                        </a>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% blogs.forEach(blog => { %>
                            <div class="col-lg-6 col-xl-6 mb-4 animate-in">
                                <div class="card blog-card h-100">
                                    <div class="position-relative">
                                        <% if (blog.coverImageURL) { %>
                                            <img src="<%= blog.coverImageURL %>" 
                                                 class="card-img-top blog-card-image" 
                                                 alt="<%= blog.title %>"
                                                 loading="lazy">
                                        <% } else { %>
                                            <div class="bg-light d-flex align-items-center justify-content-center blog-card-image">
                                                <i class="fas fa-image fa-3x text-muted"></i>
                                            </div>
                                        <% } %>
                                        <div class="blog-card-overlay"></div>
                                    </div>

                                    <div class="card-body d-flex flex-column">
                                        <div class="mb-2">
                                            <% if (blog.tags && blog.tags.length > 0) { %>
                                                <% blog.tags.slice(0, 2).forEach(tag => { %>
                                                    <a href="/blogs/tags/<%= tag %>" class="badge bg-primary-soft text-primary me-1" style="text-decoration: none;">
                                                        <%= tag %>
                                                    </a>
                                                <% }) %>
                                            <% } %>
                                        </div>

                                        <h5 class="card-title fw-bold mb-2">
                                            <%= truncate(blog.title, 60) %>
                                        </h5>

                                        <p class="card-text text-muted flex-grow-1">
                                            <%= truncate(blog.excerpt || (blog.body ? blog.body.substring(0, 120) : ''), 100) %>
                                        </p>

                                        <div class="d-flex align-items-center justify-content-between mt-3 pt-3 border-top">
                                            <div class="d-flex align-items-center gap-2">
                                                <% if (blog.createdBy) { %>
                                                    <a href="/profile/<%= blog.createdBy._id %>" class="d-flex align-items-center gap-2 text-decoration-none text-dark">
                                                        <img src="<%= blog.createdBy.profileImageURL || '/imgs/default.png' %>" 
                                                             alt="<%= blog.createdBy.fullName %>" 
                                                             width="32" height="32" 
                                                             class="rounded-circle"
                                                             onerror="this.src='/imgs/default.png';">
                                                        <div>
                                                            <small class="fw-bold d-block"><%= blog.createdBy.fullName %></small>
                                                            <small class="text-muted">
                                                                <% if (blog.readingTime) { %>
                                                                    <%= blog.readingTime %> min read
                                                                <% } %>
                                                            </small>
                                                        </div>
                                                    </a>
                                                <% } else { %>
                                                    <img src="/imgs/default.png" 
                                                         alt="Unknown Author" 
                                                         width="32" height="32" 
                                                         class="rounded-circle">
                                                    <div>
                                                        <small class="fw-bold d-block">Unknown Author</small>
                                                        <small class="text-muted">
                                                            <% if (blog.readingTime) { %>
                                                                <%= blog.readingTime %> min read
                                                            <% } %>
                                                        </small>
                                                    </div>
                                                <% } %>
                                            </div>

                                            <div class="d-flex gap-2">
                                                <div class="text-center">
                                                    <small class="text-muted d-block">
                                                        <i class="fas fa-eye"></i> <%= blog.viewCount || 0 %>
                                                    </small>
                                                </div>
                                                <div class="text-center">
                                                    <small class="text-muted d-block">
                                                        <i class="fas fa-heart"></i> <%= blog.likes ? blog.likes.length : 0 %>
                                                    </small>
                                                </div>
                                            </div>
                                        </div>

                                        <a href="/blogs/<%= blog._id %>" class="btn btn-primary btn-sm rounded-pill mt-3">
                                            <i class="fas fa-arrow-right"></i> Read Full Story
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <%# Pagination %>
                    <% if (totalPages > 1) { %>
                        <nav class="mt-5">
                            <ul class="pagination justify-content-center">
                                <% for (let i = 1; i <= totalPages; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="/?page=<%= i %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                <% } %>
                            </ul>
                        </nav>
                    <% } %>
                <% } %>
            </section>
        </main>

    <%# ==================== NOT LOGGED IN: Show Landing Page ==================== %>
    <% } else { %>

        <header class="hero-section text-center py-5 bg-primary-soft border-bottom">
            <div class="container py-5">
                <h1 class="display-4 fw-bold mb-3">Welcome to Blogify</h1>
                <p class="lead text-muted mb-4">Discover stories, insights, and ideas from amazing writers around the world.</p>
                <a href="/user/signup" class="btn btn-primary btn-lg rounded-pill me-3">
                    <i class="fas fa-pen-fancy"></i> Start Writing
                </a>
                <a href="/user/signin" class="btn btn-outline-primary btn-lg rounded-pill">
                    <i class="fas fa-book-reader"></i> Explore Blogs
                </a>
            </div>
        </header>

    <% } %>

    <%- include("./partials/scripts") %>
</body>
</html>
