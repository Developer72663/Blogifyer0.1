<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Blogify - Discover Amazing Stories</title>
</head>
<body>
    <%- include("./partials/nave") %>

    <!-- Hero Section -->
    <header class="hero-section text-center py-5 bg-primary-soft border-bottom">
        <div class="container py-5">
            <h1 class="display-4 fw-bold mb-3">Welcome to Blogify</h1>
            <p class="lead text-muted mb-4">Discover stories, insights, and ideas from amazing writers around the world.</p>
            <% if (!locals.user) { %>
                <a href="/user/signup" class="btn btn-primary btn-lg rounded-pill me-3">
                    <i class="fas fa-pen-fancy"></i> Start Writing
                </a>
                <a href="/user/signin" class="btn btn-outline-primary btn-lg rounded-pill">
                    <i class="fas fa-book-reader"></i> Explore Blogs
                </a>
            <% } %>
        </div>
    </header>

    <main class="container my-5">
        <!-- Featured Blogs -->
        <% if (typeof featuredBlogs !== 'undefined' && featuredBlogs.length > 0) { %>
            <section class="mb-5">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h2 class="fw-bold">
                        <i class="fas fa-star text-warning"></i> Featured Stories
                    </h2>
                </div>
                <div class="row">
                    <% featuredBlogs.forEach(blog => { %>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="card blog-card h-100 shadow-sm">
                                <div class="position-relative">
                                    <% if (blog.coverImageURL) { %>
                                        <img src="<%= blog.coverImageURL %>" 
                                             class="card-img-top blog-card-image" 
                                             alt="<%= blog.title %>"
                                             loading="lazy">
                                    <% } else { %>
                                        <div class="bg-light d-flex align-items-center justify-content-center blog-card-image">
                                            <i class="fas fa-image fa-3x text-muted"></i>
                                        </div>
                                    <% } %>
                                    <div class="position-absolute top-0 start-0 m-2">
                                        <span class="badge bg-warning text-dark">Featured</span>
                                    </div>
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold mb-2"><%= truncate(blog.title, 65) %></h5>
                                    <p class="card-text text-muted flex-grow-1">
                                        <%= truncate(blog.excerpt || (blog.body ? blog.body.substring(0, 120) : ''), 110) %>
                                    </p>
                                    <div class="d-flex align-items-center gap-2 mt-auto">
                                        <img src="<%= blog.createdBy.profileImageURL %>" 
                                             width="32" height="32" class="rounded-circle"
                                             onerror="this.src='/imgs/default.png';">
                                        <small class="text-muted"><%= blog.createdBy.fullName %></small>
                                    </div>
                                </div>
                                <div class="card-footer bg-white">
                                    <a href="/blogs/<%= blog._id %>" class="btn btn-primary w-100">Read Full Story</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </section>
            <hr>
        <% } %>

        <!-- Search & Filter -->
        <section class="mb-5">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <form method="GET" class="d-flex">
                        <input type="text" name="search" value="<%= search || '' %>" 
                               class="form-control rounded-start-pill" 
                               placeholder="Search blogs...">
                        <button type="submit" class="btn btn-primary rounded-end-pill">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                </div>
                <div class="col-md-3">
                    <form method="GET">
                        <select name="sort" class="form-select" onchange="this.form.submit()">
                            <option value="newest" <%= (sort === 'newest' || !sort) ? 'selected' : '' %>>Newest</option>
                            <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
                            <option value="trending" <%= sort === 'trending' ? 'selected' : '' %>>Trending</option>
                        </select>
                    </form>
                </div>
            </div>
        </section>

        <!-- Blogs Grid -->
        <section>
            <% if (!blogs || blogs.length === 0) { %>
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-5x text-muted mb-3"></i>
                    <h4>No blogs found</h4>
                </div>
            <% } else { %>
                <div class="row g-4">
                    <% blogs.forEach(blog => { %>
                        <div class="col-lg-6 col-xl-4 mb-4">
                            <div class="card blog-card h-100 shadow-sm">
                                <div class="position-relative">
                                    <% if (blog.coverImageURL) { %>
                                        <img src="<%= blog.coverImageURL %>" class="card-img-top" style="height: 200px; object-fit: cover;" alt="<%= blog.title %>">
                                    <% } %>
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold mb-2"><%= truncate(blog.title, 60) %></h5>
                                    <p class="card-text text-muted flex-grow-1">
                                        <%= truncate(blog.excerpt || (blog.body ? blog.body.substring(0, 150) : ''), 110) %>
                                    </p>
                                    <div class="mt-auto pt-3 border-top">
                                        <small class="text-muted">
                                            By <%= blog.createdBy.fullName %> • <%= blog.readingTime || 5 %> min read
                                        </small>
                                    </div>
                                </div>
                                <div class="card-footer bg-white">
                                    <a href="/blogs/<%= blog._id %>" class="btn btn-primary w-100">Read Full Story</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>

    <%- include("./partials/scripts") %>
</body>
</html>
