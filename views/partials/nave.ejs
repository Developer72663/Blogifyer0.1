<!-- Notification Center Offcanvas -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="notificationOffcanvas" aria-labelledby="notificationOffcanvasLabel" style="width: 420px; max-width: 90vw;">
    <div class="offcanvas-header border-bottom bg-light">
        <h5 class="offcanvas-title fw-bold" id="notificationOffcanvasLabel">
            <i class="fas fa-bell text-primary me-2"></i> Notifications
        </h5>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary rounded-pill" id="markAllReadBtn" onclick="markAllReadOffcanvas()">
                <i class="fas fa-check-double me-1"></i> Mark all read
            </button>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
    </div>
    <div class="offcanvas-body p-0" id="notificationsList" style="overflow-y: auto; background: #f8f9fa;">
        <div class="text-center py-5 text-muted" id="notifEmptyState">
            <i class="fas fa-bell fa-3x mb-3 opacity-25"></i>
            <p class="mb-1">No notifications yet</p>
            <small>When someone interacts with your blogs, you'll see it here.</small>
        </div>
    </div>
    <div class="offcanvas-footer border-top p-3 text-center bg-white">
        <a href="/notifications" class="btn btn-outline-primary rounded-pill px-4 fw-medium text-decoration-none">
            <i class="fas fa-external-link-alt me-2"></i> View All Notifications
        </a>
    </div>
</div>

