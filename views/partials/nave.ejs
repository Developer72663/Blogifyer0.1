</style>

<script>
    // Dark Mode Toggle
    const themeToggle = document.getElementById('themeToggle');
    const themeIcon = document.getElementById('themeIcon');
    const savedTheme = localStorage.getItem('theme') || 'light';

    function applyTheme(theme) {
        if (theme === 'dark') {
            document.body.classList.add('dark-mode');
            themeIcon.className = 'fas fa-sun';
            themeToggle.style.color = '#fbbf24';
        } else {
            document.body.classList.remove('dark-mode');
            themeIcon.className = 'fas fa-moon';
            themeToggle.style.color = '#6366f1';
        }
    }

    applyTheme(savedTheme);

    themeToggle.addEventListener('click', () => {
        const isDark = document.body.classList.contains('dark-mode');
        const newTheme = isDark ? 'light' : 'dark';
        localStorage.setItem('theme', newTheme);
        applyTheme(newTheme);
    });

    // Settings Modal Theme Buttons
    const themeLightBtn = document.getElementById('themeLightBtn');
    const themeDarkBtn = document.getElementById('themeDarkBtn');

    if (themeLightBtn && themeDarkBtn) {
        themeLightBtn.addEventListener('click', () => {
            localStorage.setItem('theme', 'light');
            applyTheme('light');
        });
        themeDarkBtn.addEventListener('click', () => {
            localStorage.setItem('theme', 'dark');
            applyTheme('dark');
        });
    }

    // ====================== NOTIFICATIONS SYSTEM ======================
    <% if (locals.user) { %>
        const notificationBell = document.getElementById('notificationBell');
        const notificationOffcanvas = new bootstrap.Offcanvas(document.getElementById('notificationOffcanvas'));
        let currentNotifications = [];

        async function loadUnreadCount() {
            try {
                const res = await fetch('/notifications/unread/count');
                const data = await res.json();
                if (data.success) {
                    const badge = document.getElementById('notificationBadge');
                    const count = document.getElementById('notificationCount');
                    const dropdownBadge = document.getElementById('dropdownNotifBadge');
                    
                    if (data.unreadCount > 0) {
                        const displayCount = data.unreadCount > 99 ? '99+' : data.unreadCount;
                        count.textContent = displayCount;
                        badge.style.display = 'block';
                        if (dropdownBadge) {
                            dropdownBadge.textContent = displayCount;
                            dropdownBadge.style.display = 'inline-block';
                        }
                    } else {
                        badge.style.display = 'none';
                        if (dropdownBadge) dropdownBadge.style.display = 'none';
                    }
                }
            } catch (err) {
                console.error('Error loading unread count:', err);
            }
        }

        async function loadNotifications() {
            try {
                const res = await fetch('/notifications?page=1&limit=15', {
                    headers: { 'Accept': 'application/json' }
                });
                const data = await res.json();

                if (data.success) {
                    currentNotifications = data.notifications;
                    renderNotifications(data.notifications);
                }
            } catch (err) {
                console.error('Error loading notifications:', err);
            }
        }

        function renderNotifications(notifications) {
            const container = document.getElementById('notificationsList');

            if (notifications.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-5 text-muted" id="notifEmptyState">
                        <i class="fas fa-bell fa-3x mb-3 opacity-25"></i>
                        <p class="mb-1">No notifications yet</p>
                        <small>When someone interacts with your blogs, you'll see it here.</small>
                    </div>
                `;
                return;
            }

            container.innerHTML = notifications.map(notif => {
                const isUnread = !notif.isRead;
                const actorName = notif.actor ? notif.actor.fullName : 'Someone';
                const actorImg = notif.actor ? (notif.actor.profileImageURL || '/imgs/default.png') : '/imgs/default.png';
                const blogImg = notif.blog ? (notif.blog.coverImageURL || '/imgs/default-blog.png') : null;
                const blogTitle = notif.blog ? notif.blog.title : '';
                const blogId = notif.blog ? notif.blog._id : '';
                const timeAgo = getTimeAgo(notif.createdAt);

                let iconClass = 'fa-bell';
                let iconColor = '#6366f1';
                let actionText = '';

                switch(notif.type) {
                    case 'blog_post':
                        iconClass = 'fa-file-alt';
                        iconColor = '#10b981';
                        actionText = 'published a new blog';
                        break;
                    case 'like':
                        iconClass = 'fa-heart';
                        iconColor = '#ef4444';
                        actionText = 'liked your blog';
                        break;
                    case 'comment':
                        iconClass = 'fa-comment';
                        iconColor = '#3b82f6';
                        actionText = 'commented on your blog';
                        break;
                    case 'reply':
                        iconClass = 'fa-reply';
                        iconColor = '#8b5cf6';
                        actionText = 'replied to your comment';
                        break;
                    case 'follow':
                        iconClass = 'fa-user-plus';
                        iconColor = '#f59e0b';
                        actionText = 'started following you';
                        break;
                    case 'mention':
                        iconClass = 'fa-at';
                        iconColor = '#ec4899';
                        actionText = 'mentioned you';
                        break;
                }

                return `
                    <div class="notification-item p-3 border-bottom ${isUnread ? 'bg-white' : ''}" 
                         data-id="${notif._id}" 
                         style="cursor: pointer; transition: all 0.2s;"
                         onclick="handleNotificationClick('${notif._id}', '${notif.type}', '${blogId}', '${notif.actor ? notif.actor._id : ''}')">
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0 position-relative">
                                <img src="${actorImg}" 
                                     alt="${actorName}" 
                                     class="rounded-circle" 
                                     width="44" 
                                     height="44" 
                                     style="object-fit: cover; border: 2px solid ${isUnread ? iconColor : '#e5e7eb'};"
                                     onerror="this.src='/imgs/default.png';">
                                <span class="position-absolute bottom-0 end-0 translate-middle-y badge rounded-circle p-1" 
                                      style="background: ${iconColor}; font-size: 0.6rem; border: 2px solid white;">
                                    <i class="fas ${iconClass} text-white" style="font-size: 0.5rem;"></i>
                                </span>
                            </div>
                            <div class="flex-grow-1" style="min-width: 0;">
                                <p class="mb-1 small fw-medium" style="line-height: 1.5; color: #1a1a2e;">
                                    ${actorName} <span class="fw-normal text-muted">${actionText}</span>
                                </p>
                                ${blogTitle ? `<p class="mb-1 text-muted small text-truncate" style="font-size: 0.8rem;"><i class="fas fa-book-open me-1 opacity-50"></i>${blogTitle}</p>` : ''}
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-muted" style="font-size: 0.75rem;">${timeAgo}</small>
                                    ${isUnread ? '<span class="badge bg-primary rounded-pill" style="font-size: 0.6rem;">New</span>' : ''}
                                </div>
                            </div>
                            <div class="flex-shrink-0">
                                <button class="btn btn-sm btn-link text-danger p-1 opacity-50 hover-opacity-100" 
                                        onclick="event.stopPropagation(); deleteNotification('${notif._id}', this)"
                                        title="Delete"
                                        style="transition: opacity 0.2s;">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </div>
                        ${blogImg ? `
                            <div class="mt-2 ms-5 rounded-3 overflow-hidden">
                                <img src="${blogImg}" 
                                     class="w-100" 
                                     style="height: 100px; object-fit: cover;" 
                                     onerror="this.style.display='none';">
                            </div>
                        ` : ''}
                    </div>
                `;
            }).join('');
        }

        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - new Date(date)) / 1000);
            const intervals = { year: 31536000, month: 2592000, week: 604800, day: 86400, hour: 3600, minute: 60 };
            for (const [unit, secs] of Object.entries(intervals)) {
                const count = Math.floor(seconds / secs);
                if (count >= 1) return `${count} ${unit}${count > 1 ? 's' : ''} ago`;
            }
            return 'Just now';
        }

        async function handleNotificationClick(id, type, blogId, actorId) {
            try {
                await fetch(`/notifications/${id}/read`, { method: 'PUT' });
                loadUnreadCount();
            } catch (e) { console.error(e); }

            if (type === 'follow' && actorId) {
                window.location.href = `/user/profile/${actorId}`;
            } else if (blogId) {
                window.location.href = `/blogs/${blogId}`;
            }
        }

        async function markAllReadOffcanvas() {
            try {
                const res = await fetch('/notifications/all/read', { method: 'PUT' });
                const data = await res.json();
                if (data.success) {
                    document.querySelectorAll('.notification-item').forEach(item => {
                        item.classList.remove('bg-white');
                        item.style.background = 'transparent';
                        const badge = item.querySelector('.badge.bg-primary');
                        if (badge) badge.remove();
                    });
                    loadUnreadCount();
                }
            } catch (e) { console.error(e); }
        }

        async function deleteNotification(id, btn) {
            if (!confirm('Delete this notification?')) return;
            
            const item = btn.closest('.notification-item');
            item.style.transition = 'all 0.3s ease';
            item.style.opacity = '0';
            item.style.transform = 'translateX(30px)';
            
            try {
                const res = await fetch(`/notifications/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    setTimeout(() => {
                        item.remove();
                        loadUnreadCount();
                        if (document.querySelectorAll('.notification-item').length === 0) {
                            document.getElementById('notificationsList').innerHTML = `
                                <div class="text-center py-5 text-muted" id="notifEmptyState">
                                    <i class="fas fa-bell fa-3x mb-3 opacity-25"></i>
                                    <p class="mb-1">No notifications yet</p>
                                    <small>When someone interacts with your blogs, you'll see it here.</small>
                                </div>
                            `;
                        }
                    }, 300);
                }
            } catch (e) {
                item.style.opacity = '1';
                item.style.transform = 'none';
            }
        }

        notificationBell.addEventListener('click', () => {
            notificationOffcanvas.show();
            loadNotifications();
        });

        loadUnreadCount();
        setInterval(loadUnreadCount, 30000);

        // Settings Button
        const settingsBtn = document.getElementById('settingsBtn');
        const settingsModal = new bootstrap.Modal(document.getElementById('settingsModal'));
        settingsBtn.addEventListener('click', (e) => {
            e.preventDefault();
            settingsModal.show();
        });
    <% } %>
</script>
